# Lead delivery configuration
# ---------------------------------------------------------------------------
# The contact form delivers leads through any channel configured below. If
# NEITHER is set, submissions are logged to the server console only — set at
# least one before going live so leads are actually delivered somewhere.

# Option A (recommended): Resend API key (https://resend.com — free tier is
# plenty). Leads are emailed directly to CONTACT_FORM_NOTIFY_EMAIL.
RESEND_API_KEY=

# Option B: URL of a webhook (Zapier, Make, a serverless function, your CRM,
# etc.) that will receive JSON POST bodies for every contact form submission.
CONTACT_FORM_WEBHOOK_URL=

# Where lead notification emails are sent (Resend), and included in the
# webhook payload so your automation can route notifications.
CONTACT_FORM_NOTIFY_EMAIL=info@secondalarminvasivecontrol.com

# Optional: the From address for Resend lead emails. Until you verify your
# domain in Resend, leave this unset — the default onboarding@resend.dev
# sender works out of the box (but can only deliver to your own Resend
# account email).
CONTACT_FORM_FROM_EMAIL=

# Public site URL (used for canonical links, sitemap, and structured data).
NEXT_PUBLIC_SITE_URL=https://www.secondalarminvasivecontrol.com
