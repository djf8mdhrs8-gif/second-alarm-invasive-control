# Contact form configuration
# ---------------------------------------------------------------------------
# URL of a webhook (Zapier, Make, a serverless function, your CRM, etc.) that
# will receive JSON POST bodies for every contact form submission. If left
# unset, submissions are logged to the server console only — set this before
# going live so leads are actually delivered somewhere.
CONTACT_FORM_WEBHOOK_URL=

# Email address included in the payload sent to the webhook above, so your
# automation can route notifications to the right inbox.
CONTACT_FORM_NOTIFY_EMAIL=info@secondalarminvasive.com

# Public site URL (used for canonical links, sitemap, and structured data).
# Update this once a production domain is live.
NEXT_PUBLIC_SITE_URL=https://www.secondalarminvasive.com
